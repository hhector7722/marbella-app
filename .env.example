# IA (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi

# STT (Speech-to-Text)
# Proveedor STT: openai | whisper_local
STT_PROVIDER=openai
# Clave OpenAI si STT_PROVIDER=openai
OPENAI_API_KEY=
# Comando local si STT_PROVIDER=whisper_local (debe aceptar {file})
WHISPER_COMMAND=
# Límite máximo por archivo STT en MB (opcional). Si no existe, usa 10.
MAX_STT_FILE_MB=10

# Voice WS server (streaming)
VOICE_WS_SECRET=changeme_secure_secret_here
VOICE_TOKEN_TTL_SECONDS=120
VOICE_WS_PORT=8081
STT_CHUNK_INTERVAL_MS=1500
VOICE_WS_MAX_CONCURRENT=8
# Base URL del Next.js server al que el voice-server llama internamente
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# URL pública del WS (solo host/puerto, sin secretos)
NEXT_PUBLIC_VOICE_WS_URL=ws://localhost:8081

